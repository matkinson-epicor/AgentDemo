@model List<NewsArticleViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to AgentDemo</h1>
    <p class="lead">A .NET 9 ASP.NET Core web application created with Amazon Q Agent</p>
    
    <!-- In the News Section with Sliding Panel/Banner -->
    <div class="news-section mt-5">
        <h2 class="section-title text-center">In the News</h2>
        <div class="news-carousel-container">
            <div class="news-carousel">
                @foreach (var article in Model)
                {
                    <div class="news-item">
                        <div class="news-image">
                            <img src="@article.ImageUrl" alt="@article.Title" class="img-fluid rounded">
                        </div>
                        <div class="news-content">
                            <h3>@article.Title</h3>
                            <p class="news-date">@article.PublishedDate.ToString("MMMM dd, yyyy")</p>
                            <p>@article.Summary</p>
                            <a href="@article.LinkUrl" class="btn btn-primary">Read More</a>
                        </div>
                    </div>
                }
            </div>
            
            <!-- Navigation Dots -->
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Count; i++)
                {
                    <button type="button" data-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
                }
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h2>About This Application</h2>
        <p>
            This is a demonstration project showcasing a basic ASP.NET Core MVC application structure.
            It includes controllers, views, and models following standard ASP.NET Core conventions.
        </p>
        
        <div class="alert alert-info mt-3">
            <h4>Need to get in touch?</h4>
            <p>Visit our <a asp-controller="Home" asp-action="Contact" class="alert-link">Contact Us</a> page for sales inquiries, technical support, or to provide feedback.</p>
        </div>
        
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h3>Features</h3>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">ASP.NET Core MVC architecture</li>
                            <li class="list-group-item">Bootstrap styling</li>
                            <li class="list-group-item">Responsive design</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h3>Technologies</h3>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">.NET 9</li>
                            <li class="list-group-item">ASP.NET Core</li>
                            <li class="list-group-item">C#</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h3>Structure</h3>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Controllers</li>
                            <li class="list-group-item">Views</li>
                            <li class="list-group-item">Models</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize the news carousel when the document is ready
        $(document).ready(function() {
            initNewsCarousel();
        });
    </script>
}